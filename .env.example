# Copy this file to .env and fill in your keys.

# OpenAI (used for dense embeddings + chat LLM)
OPENAI_API_KEY=sk-...

# Qwen via DashScope (used for image OCR + scanned PDFs)
# Get one at https://dashscope.aliyun.com/
QWEN_API_KEY=sk-...

# --- Qdrant (vector database) ---
# Pick ONE of the following:
#
#   1. LOCAL EMBEDDED MODE (default, zero setup)
#      Leave QDRANT_URL unset and Qdrant will run as an in-process
#      embedded DB writing to ./qdrant_storage/
#
#   2. DOCKER / REMOTE / CLOUD MODE
#      Set QDRANT_URL to the running server's URL.
#      For Qdrant Cloud, also set QDRANT_API_KEY.
#
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Optional override for the embedded storage path
# QDRANT_PATH=./qdrant_storage

# Optional override for the collection name
# QDRANT_COLLECTION=adaptive_rag

# --- Models (all optional — sensible defaults are baked in) ---

# Dense embedding model (must match DENSE_SIZE)
# DENSE_MODEL=text-embedding-3-small
# DENSE_SIZE=1536

# Sparse embedding model (BM25 via FastEmbed)
# SPARSE_MODEL=Qdrant/bm25

# Chunking
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=200

# --- Retrieval & reranking ---

# How many candidates to fetch from Qdrant before reranking
# RETRIEVAL_PREFETCH_K=25

# Final number of chunks passed to the LLM after reranking
# RERANK_TOP_K=5

# FlashRank model. Lightweight options (size · quality):
#   ms-marco-TinyBERT-L-2-v2          (~4 MB, fastest)
#   ms-marco-MiniLM-L-12-v2           (~34 MB, balanced)  ← default
#   ms-marco-MultiBERT-L-12           (~150 MB, multilingual)
#   rank-T5-flan                      (~110 MB, best quality)
# RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# --- LLM (used by the chat synthesis layer) ---

# LLM_MODEL=gpt-4.1-mini
# LLM_TEMPERATURE=0.2
